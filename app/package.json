{
  "name": "ros2-node-map-app",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "test": "node ../scripts/version.mjs check && node --experimental-strip-types --test tests/*.test.mjs",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "package:backend": "node scripts/package-backend.mjs",
    "electron:dev": "concurrently -k \"vite\" \"tsc -p electron/tsconfig.json --watch\" \"wait-on tcp:5173 file:dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "preview": "vite preview",
    "dist": "npm run build && npm run package:backend && electron-builder --linux AppImage"
  },
  "dependencies": {
    "@lumino/commands": "2.3.2",
    "@lumino/default-theme": "2.1.0",
    "@lumino/widgets": "2.7.5",
    "cytoscape": "3.34.0",
    "cytoscape-cola": "2.5.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "wait-on": "9.0.10"
  },
  "build": {
    "appId": "io.github.ros2-node-map",
    "productName": "ros2-node-map",
    "asar": true,
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/ros2_node_map",
        "to": "backend/ros2_node_map"
      },
      {
        "from": "../backend/.package-runtime/site-packages",
        "to": "backend/site-packages"
      }
    ],
    "linux": {
      "artifactName": "${productName}-v${version}-${os}-${arch}.${ext}",
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "executableName": "ros2-node-map"
    }
  }
}
